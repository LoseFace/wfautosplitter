{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "WFAutoSplitter",
  "version": "1.1.3",
  "identifier": "WFAutoSplitter",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "WFAutoSplitter",
        "width": 1200,
        "height": 400,
        "minWidth": 700,
        "minHeight": 275,
        "zoomHotkeysEnabled": true,
        "backgroundColor": "#1e1e1e",
        "visible": true,
        "transparent": false
      },
      {
        "label": "overlay-window",
        "title": "Overlay Window",
        "width": 100,
        "height": 100,
        "minWidth": 1,
        "minHeight": 1,
        "resizable": false,
        "visible": false,
        "center": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "focus": false,
        "skipTaskbar": true,
        "shadow": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' https://api.github.com",
      "capabilities": ["default"]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.ico"
    ],
    "resources": [
      "resources/default_templates.json"
    ]
  }
}
